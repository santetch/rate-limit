{
  "name": "rate-limiter",
  "packageManager": "yarn@4.5.3",
  "scripts": {
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:e2e": "jest tests/e2e",
    "test:cov": "jest --coverage",
    "test:docker": "jest tests/docker --testPathIgnorePatterns=/node_modules/ --testTimeout=120000 --forceExit",
    "start": "nest start swc -w",
    "build": "nest build",
    "start:prod": "node dist/rate-limiter/src/main.js",
    "migration:run:prod": "node dist/rate-limiter/src/database/run-migrations.js",
    "docker:up": "sh -c 'docker compose up --build --scale app=${0:-1}'",
    "docker:down": "docker compose down -v",
    "typeorm": "typeorm-ts-node-commonjs -d rate-limiter/src/database/data-source.ts",
    "migration:generate": "yarn typeorm migration:generate",
    "migration:run": "yarn typeorm migration:run",
    "migration:revert": "yarn typeorm migration:revert"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/swagger": "^11.4.1",
    "@nestjs/typeorm": "^11.0.1",
    "@sentry/nestjs": "^10.50.0",
    "@sentry/profiling-node": "^10.50.0",
    "axios": "^1.15.2",
    "ioredis": "^5.10.1",
    "nestjs-pino": "^4.6.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/testing": "^11.1.19",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.30",
    "@types/express": "^5.0.6",
    "@types/ioredis-mock": "^8.2.7",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8",
    "@types/supertest": "^7.2.0",
    "ioredis-mock": "^8.13.1",
    "jest": "^30.3.0",
    "jest-environment-node": "^30.3.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
